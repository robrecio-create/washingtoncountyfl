---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import eventsData from '../data/events.json';

const events = (eventsData as any[]).filter(e => e.status === 'publish');

// Sort by date ascending (upcoming first)
events.sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

function formatDate(dateStr: string) {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
}

function getMonthDay(dateStr: string) {
  const date = new Date(dateStr + 'T00:00:00');
  return {
    month: date.toLocaleDateString('en-US', { month: 'short' }).toUpperCase(),
    day: date.getDate(),
  };
}
---

<Layout
  title="Events — Jackson County MS"
  description="Browse upcoming community events in Jackson County, Mississippi. Festivals, markets, fundraisers, and more in Ocean Springs, Pascagoula, Gautier, and beyond."
>
  <Header activePage="Events" />

  <section class="page-hero">
    <div class="container">
      <span class="page-eyebrow">What's Happening</span>
      <h1>Community Events</h1>
      <p>Discover upcoming events, festivals, and activities across Jackson County.</p>
    </div>
  </section>

  <section class="events-section">
    <div class="container">
      <div class="search-bar">
        <input type="text" id="event-search" placeholder="Search events..." autocomplete="off" aria-label="Search events" />
      </div>
      <p class="result-count" id="event-result-count">{events.length} event{events.length === 1 ? '' : 's'}</p>

      {events.length > 0 ? (
        <div class="events-list" id="events-list">
          {events.map(event => {
            const { month, day } = getMonthDay(event.date);
            return (
              <a href={`/event/${event.slug}/`} class="event-card" data-name={event.title.toLowerCase()} data-location={(event.location || '').toLowerCase()}>
                <div class="event-date-badge">
                  <span class="event-month">{month}</span>
                  <span class="event-day">{day}</span>
                </div>
                <div class="event-info">
                  <h3>{event.title}</h3>
                  <div class="event-meta">
                    <span class="event-meta-item">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      {event.start_time}{event.end_time ? ` – ${event.end_time}` : ''}
                    </span>
                    <span class="event-meta-item">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                      {event.venue}
                    </span>
                    {event.location && (
                      <span class="event-meta-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                        {event.location}
                      </span>
                    )}
                  </div>
                  {event.recurring && <span class="event-recurring">{event.recurring}</span>}
                  <p class="event-excerpt">{event.content.substring(0, 150)}...</p>
                </div>
                <div class="event-arrow">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="empty-state">
          <span class="empty-icon">📅</span>
          <h3>No Upcoming Events</h3>
          <p>Check back soon for community events across Jackson County.</p>
        </div>
      )}

      <p class="no-results" id="event-no-results" style="display:none;">No events found. Try a different search term.</p>

      <div class="cta-block">
        <h2>Have an Event to Share?</h2>
        <p>Let us know about upcoming community events in Jackson County and we'll add them to the calendar.</p>
        <a href="/submit-event/" class="btn btn-gold">Submit an Event</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
    padding: 8rem 0 3.5rem;
    text-align: center;
  }

  .page-eyebrow {
    display: inline-block;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .page-hero p {
    color: rgba(255,255,255,0.7);
    font-size: 1.1rem;
  }

  .events-section {
    padding: 3.5rem 0 5rem;
    background: var(--gray-100);
  }

  .events-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .event-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-decoration: none;
    transition: all 0.25s;
  }

  .event-card:hover {
    border-color: var(--teal);
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .event-date-badge {
    flex-shrink: 0;
    width: 70px;
    height: 70px;
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .event-month {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    color: var(--gold);
  }

  .event-day {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
  }

  .event-info {
    flex: 1;
    min-width: 0;
  }

  .event-info h3 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--navy);
    margin-bottom: 0.4rem;
  }

  .event-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .event-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--gray-500);
  }

  .event-meta-item svg {
    color: var(--teal);
    flex-shrink: 0;
  }

  .event-recurring {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--teal);
    background: rgba(0,128,128,0.08);
    padding: 0.15rem 0.6rem;
    border-radius: 100px;
    margin-bottom: 0.5rem;
  }

  .event-excerpt {
    font-size: 0.85rem;
    color: var(--gray-600);
    line-height: 1.5;
    margin: 0;
  }

  .event-arrow {
    flex-shrink: 0;
    color: var(--gray-300);
    transition: all 0.25s;
  }

  .event-card:hover .event-arrow {
    color: var(--teal);
    transform: translateX(3px);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    margin-bottom: 4rem;
  }

  .empty-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 1rem;
  }

  .empty-state h3 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    color: var(--navy);
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    color: var(--gray-600);
  }

  .cta-block {
    text-align: center;
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
    border-radius: var(--radius-xl);
    padding: 3.5rem 2rem;
  }

  .cta-block h2 {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .cta-block p {
    color: rgba(255,255,255,0.7);
    margin-bottom: 1.5rem;
    max-width: 450px;
    margin-left: auto;
    margin-right: auto;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.6rem;
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: var(--radius-md);
    border: 2px solid transparent;
    transition: all 0.25s;
  }

  .btn-gold {
    background: var(--gold);
    color: var(--navy);
    border-color: var(--gold);
  }

  .btn-gold:hover {
    background: var(--gold-light);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(232,160,32,0.35);
  }

  .search-bar {
    max-width: 480px;
    margin: 0 auto 1rem;
  }

  .search-bar input {
    width: 100%;
    padding: 0.85rem 1.25rem;
    font-size: 1rem;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    background: var(--white);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .search-bar input:focus {
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(0,128,128,0.1);
  }

  .result-count {
    text-align: center;
    font-size: 0.85rem;
    color: var(--gray-600);
    margin-bottom: 1.5rem;
  }

  .no-results {
    text-align: center;
    color: var(--gray-500);
    font-size: 0.95rem;
    padding: 3rem 1rem;
    font-style: italic;
  }

  @media (max-width: 600px) {
    .event-card {
      flex-direction: column;
      align-items: flex-start;
    }
    .event-date-badge {
      width: 60px;
      height: 60px;
    }
    .event-arrow { display: none; }
    .cta-block { padding: 2.5rem 1.5rem; }
  }
</style>

<script>
  const input = document.getElementById('event-search') as HTMLInputElement;
  const list = document.getElementById('events-list')!;
  const countEl = document.getElementById('event-result-count')!;
  const noResults = document.getElementById('event-no-results')!;
  const cards = Array.from(list?.querySelectorAll('.event-card') || []) as HTMLElement[];

  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    let visible = 0;
    cards.forEach(card => {
      const nameMatch = card.dataset.name?.includes(q);
      const locMatch = card.dataset.location?.includes(q);
      const match = !q || nameMatch || locMatch;
      card.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    countEl.textContent = `${visible} event${visible === 1 ? '' : 's'}`;
    noResults.style.display = visible === 0 ? '' : 'none';
  });
</script>
