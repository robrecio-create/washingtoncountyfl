---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { categories, towns } from '../data/constants';
import { getJacksonBusinesses } from '../lib/businesses';
import { createClient } from '@supabase/supabase-js';

const allBusinessData = await getJacksonBusinesses();
const businesses = allBusinessData.sort((a: any, b: any) => {
  // Elevated/SEO first, then Featured, then free
  const tierRank = (biz: any) => {
    if (biz.listing_tier === 'elevated' || biz.listing_tier === 'seo') return 0;
    if (biz.featured || biz.listing_tier === 'featured') return 1;
    return 2;
  };
  const rankDiff = tierRank(a) - tierRank(b);
  if (rankDiff !== 0) return rankDiff;
  return a.title.localeCompare(b.title);
});

// Fetch verified business slugs from Supabase
const verifiedSlugs = new Set<string>();
const supabaseUrl = import.meta.env.SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;
if (supabaseUrl && supabaseKey) {
  try {
    const supabase = createClient(supabaseUrl, supabaseKey);
    const { data: claims } = await supabase
      .from('business_claims')
      .select('business_id, businesses!inner(slug)')
      .eq('status', 'approved');
    if (claims) {
      for (const c of claims) {
        const biz = (c as any).businesses;
        if (biz?.slug) verifiedSlugs.add(biz.slug);
      }
    }
  } catch {}
}
---

<Layout
  title="All Listings — Jackson County MS"
  description="Browse all local businesses in Jackson County, Mississippi. Filter by category or city — restaurants, contractors, healthcare, retail, and more."
>
  <Header activePage="Listings" />

  <section class="page-hero">
    <div class="container">
      <span class="page-eyebrow">Business Directory</span>
      <h1>All Listings</h1>
      <p>Browse all {businesses.length} businesses across Jackson County, Mississippi.</p>
    </div>
  </section>

  <section class="listings-section">
    <div class="container">
      <div class="listings-controls">
        <div class="search-filter">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" id="search-input" placeholder="Search businesses..." aria-label="Search businesses" />
        </div>
        <div class="filter-row">
          <select id="filter-city" aria-label="Filter by city">
            <option value="">All Cities</option>
            {towns.map(t => <option value={t.name}>{t.name}</option>)}
          </select>
          <select id="filter-category" aria-label="Filter by category">
            <option value="">All Categories</option>
            {categories.map(c => <option value={c.name}>{c.name}</option>)}
          </select>
        </div>
      </div>

      <p class="results-count" id="results-count">{businesses.length} businesses</p>

      <div class="listings-grid" id="listings-grid">
        {businesses.map(biz => (
          <a href={`/listing/${biz.slug}/`} class={`listing-card ${(biz.listing_tier === 'elevated' || biz.listing_tier === 'seo') ? 'listing-card-elevated' : ''}`} data-city={biz.location?.[0] || ''} data-category={biz.categories?.[0] || ''} data-name={biz.title.toLowerCase()}>
            <div class="listing-top">
              <h3>{biz.title}</h3>
              <div class="listing-badges">
                {(biz.listing_tier === 'elevated' || biz.listing_tier === 'seo') && <span class="badge-elevated">★ Elevated</span>}
                {biz.featured && biz.listing_tier !== 'elevated' && biz.listing_tier !== 'seo' && <span class="badge-featured">Featured</span>}
                {verifiedSlugs.has(biz.slug) && <span class="badge-verified">&#10003; Verified</span>}
                {biz.tags?.includes('locally-owned') && <span class="badge-local">Locally Owned</span>}
              </div>
            </div>
            {biz.content && <p class="listing-desc">{biz.content.substring(0, 120)}{biz.content.length > 120 ? '...' : ''}</p>}
            <div class="listing-meta">
              {biz.categories?.[0] && <span class="listing-cat">{biz.categories[0]}</span>}
              {biz.location?.[0] && <span class="listing-loc">📍 {biz.location[0]}</span>}
            </div>
            {biz.phone && <span class="listing-phone">📞 {biz.phone}</span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
    padding: 8rem 0 3.5rem;
    text-align: center;
  }

  .page-eyebrow {
    display: inline-block;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .page-hero p {
    color: rgba(255,255,255,0.7);
    font-size: 1.1rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .listings-section {
    padding: 3rem 0 5rem;
    background: var(--gray-100);
  }

  .listings-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .search-filter {
    flex: 1;
    min-width: 250px;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    padding: 0 1rem;
  }

  .search-filter svg { color: var(--gray-400); flex-shrink: 0; }

  .search-filter input {
    flex: 1;
    border: none;
    padding: 0.85rem 0;
    font-size: 0.95rem;
    font-family: var(--font-body);
    outline: none;
    background: transparent;
    color: var(--gray-800);
  }

  .filter-row {
    display: flex;
    gap: 0.75rem;
  }

  .filter-row select {
    padding: 0.85rem 1rem;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 0.9rem;
    background: var(--white);
    color: var(--gray-800);
    cursor: pointer;
    outline: none;
    min-width: 160px;
  }

  .filter-row select:focus {
    border-color: var(--teal);
  }

  .results-count {
    font-size: 0.9rem;
    color: var(--gray-600);
    margin-bottom: 1.5rem;
  }

  .listings-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .listing-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    transition: all 0.25s;
  }

  .listing-card:hover {
    border-color: var(--teal);
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .listing-card-elevated {
    border: 2px solid rgba(167,139,250,0.4);
    background: linear-gradient(135deg, #faf5ff 0%, #f5f0ff 100%);
    box-shadow: 0 2px 12px rgba(167,139,250,0.1);
    position: relative;
  }
  .listing-card-elevated::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #a78bfa, #7c3aed, #a78bfa);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
  }
  .listing-card-elevated:hover {
    border-color: #a78bfa;
    box-shadow: 0 6px 24px rgba(167,139,250,0.2);
  }

  .listing-top {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }

  .listing-top h3 {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--navy);
    line-height: 1.3;
  }

  .listing-badges {
    display: flex;
    gap: 0.35rem;
    flex-shrink: 0;
  }

  .badge-elevated {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #a78bfa;
    background: rgba(167,139,250,0.12);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .badge-featured {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--gold);
    background: rgba(232,160,32,0.12);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .badge-verified {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #34d399;
    background: rgba(52,211,153,0.12);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .badge-local {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--teal);
    background: rgba(26,127,122,0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .listing-desc {
    font-size: 0.85rem;
    color: var(--gray-600);
    line-height: 1.5;
    margin-bottom: 0.75rem;
    flex: 1;
  }

  .listing-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }

  .listing-cat {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--teal);
    background: rgba(26,127,122,0.08);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
  }

  .listing-loc {
    font-size: 0.78rem;
    color: var(--gray-600);
  }

  .listing-phone {
    font-size: 0.8rem;
    color: var(--gray-600);
    margin-top: 0.25rem;
  }

  @media (max-width: 900px) {
    .listings-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .listings-grid { grid-template-columns: 1fr; }
    .listings-controls { flex-direction: column; }
    .filter-row { flex-direction: column; }
    .filter-row select { min-width: 100%; }
  }
</style>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const cityFilter = document.getElementById('filter-city') as HTMLSelectElement;
  const catFilter = document.getElementById('filter-category') as HTMLSelectElement;
  const grid = document.getElementById('listings-grid')!;
  const countEl = document.getElementById('results-count')!;
  const cards = Array.from(grid.querySelectorAll('.listing-card')) as HTMLElement[];

  function filterListings() {
    const q = searchInput.value.toLowerCase().trim();
    const city = cityFilter.value;
    const cat = catFilter.value;
    let visible = 0;

    cards.forEach(card => {
      const name = card.dataset.name || '';
      const cardCity = card.dataset.city || '';
      const cardCat = card.dataset.category || '';
      const matchSearch = !q || name.includes(q);
      const matchCity = !city || cardCity === city;
      const matchCat = !cat || cardCat === cat;
      const show = matchSearch && matchCity && matchCat;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    countEl.textContent = `${visible} business${visible !== 1 ? 'es' : ''}`;
  }

  searchInput.addEventListener('input', filterListings);
  cityFilter.addEventListener('change', filterListings);
  catFilter.addEventListener('change', filterListings);

  // Pre-fill search from URL param ?q=
  const urlQ = new URLSearchParams(window.location.search).get('q');
  if (urlQ) {
    searchInput.value = urlQ;
    filterListings();
    searchInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
</script>
