---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getJacksonBusinesses } from '../../lib/businesses';
import { createClient } from '@supabase/supabase-js';

export async function getStaticPaths() {
  const businesses = await getJacksonBusinesses();
  return businesses.map(biz => ({
    params: { slug: biz.slug },
    props: { business: biz, allBusinesses: businesses },
  }));
}

const { business, allBusinesses } = Astro.props;
const biz = business as any;
const COUNTY = 'jackson';

// Supabase client for build-time queries
let photos: any[] = [];
let reviews: any[] = [];
let isVerified = false;
let sbBizData: any = null;

const supabaseUrl = import.meta.env.SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;

if (supabaseUrl && supabaseKey) {
  try {
    const supabase = createClient(supabaseUrl, supabaseKey);

    // Look up business UUID by county + slug
    const { data: sbBiz } = await supabase
      .from('businesses')
      .select('id, services, video_url, listing_tier, banner_image_url, logo_url, facebook_url, instagram_url, twitter_url, linkedin_url, tiktok_url, youtube_url, business_hours, cta_1_label, cta_1_url, cta_2_label, cta_2_url')
      .eq('county', COUNTY)
      .eq('slug', biz.slug)
      .single();

    if (sbBiz) {
      sbBizData = sbBiz;

      // Fetch photos
      const { data: photoData } = await supabase
        .from('business_photos')
        .select('*')
        .eq('business_id', sbBiz.id)
        .order('is_primary', { ascending: false })
        .order('sort_order', { ascending: true });
      if (photoData) photos = photoData;

      // Fetch approved reviews (featured only)
      if (biz.featured) {
        const { data: reviewData } = await supabase
          .from('business_reviews')
          .select('*')
          .eq('business_id', sbBiz.id)
          .eq('status', 'approved')
          .order('created_at', { ascending: false });
        if (reviewData) reviews = reviewData;
      }

      // Check if business is claimed/verified
      const { data: claimData } = await supabase
        .from('business_claims')
        .select('id')
        .eq('business_id', sbBiz.id)
        .eq('status', 'approved')
        .limit(1);
      if (claimData && claimData.length > 0) isVerified = true;
    }
  } catch (e) {
    // Silently fail — all features are optional
  }
}

const primaryPhoto = photos.find((p: any) => p.is_primary) || photos[0];
const otherPhotos = photos.filter((p: any) => p !== primaryPhoto);

// Parse services from Supabase (newline-separated)
const services = (sbBizData?.services || '').split('\n').map((s: string) => s.trim()).filter(Boolean);

// Parse video embed URL
const videoUrl = sbBizData?.video_url || '';
let videoEmbedUrl = '';
if (videoUrl) {
  const ytMatch = videoUrl.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/);
  const vimeoMatch = videoUrl.match(/vimeo\.com\/(\d+)/);
  if (ytMatch) videoEmbedUrl = `https://www.youtube.com/embed/${ytMatch[1]}`;
  else if (vimeoMatch) videoEmbedUrl = `https://player.vimeo.com/video/${vimeoMatch[1]}`;
}

// Average rating
const avgRating = reviews.length > 0
  ? reviews.reduce((sum: number, r: any) => sum + r.rating, 0) / reviews.length
  : 0;

// Related businesses
const related = (allBusinesses as any[])
  .filter(b =>
    b.slug !== biz.slug &&
    (b.categories?.[0] === biz.categories?.[0] || b.location?.[0] === biz.location?.[0])
  )
  .slice(0, 3);

// Tier config
const isFeatured = biz.featured === true;
const listingTier = sbBizData?.listing_tier || (isFeatured ? 'featured' : 'free');
const isElevated = listingTier === 'elevated' || listingTier === 'seo';

// Elevated premium fields
const bannerUrl = sbBizData?.banner_image_url || '';
const logoUrl = sbBizData?.logo_url || '';
const socialLinks = [
  { name: 'Facebook', url: sbBizData?.facebook_url, icon: 'fb' },
  { name: 'Instagram', url: sbBizData?.instagram_url, icon: 'ig' },
  { name: 'Twitter', url: sbBizData?.twitter_url, icon: 'tw' },
  { name: 'LinkedIn', url: sbBizData?.linkedin_url, icon: 'li' },
  { name: 'TikTok', url: sbBizData?.tiktok_url, icon: 'tt' },
  { name: 'YouTube', url: sbBizData?.youtube_url, icon: 'yt' },
].filter(s => s.url);
const businessHours = sbBizData?.business_hours || null;
const cta1 = sbBizData?.cta_1_label && sbBizData?.cta_1_url ? { label: sbBizData.cta_1_label, url: sbBizData.cta_1_url } : null;
const cta2 = sbBizData?.cta_2_label && sbBizData?.cta_2_url ? { label: sbBizData.cta_2_label, url: sbBizData.cta_2_url } : null;

// Tab config for featured businesses
const hasDeal = !!biz.deal_title;
const hasServices = services.length > 0;
const hasGallery = photos.length > 0 || !!videoEmbedUrl;

// SEO description: use excerpt, or first 155 chars of content, or fallback
const rawDesc = biz.excerpt || biz.content || '';
const seoDescription = rawDesc.length > 155
  ? rawDesc.slice(0, 152).trimEnd() + '...'
  : rawDesc || `${biz.title} is a local business in ${biz.location?.[0] || 'Jackson County'}, Mississippi. Find contact info, hours, and more.`;
---

<Layout
  title={`${biz.title} — Jackson County MS`}
  description={seoDescription}
  ogImage={primaryPhoto?.url || undefined}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": biz.title,
    "description": seoDescription,
    "address": biz.address ? {
      "@type": "PostalAddress",
      "streetAddress": biz.address,
      "addressLocality": biz.location?.[0] || "Jackson County",
      "addressRegion": "MS",
      "addressCountry": "US"
    } : undefined,
    "telephone": biz.phone || undefined,
    "email": biz.email || undefined,
    "url": biz.website || `https://www.jacksoncountyms.com/listing/${biz.slug}/`,
    "image": primaryPhoto?.url || undefined,
    "geo": (biz.latitude && biz.longitude) ? {
      "@type": "GeoCoordinates",
      "latitude": biz.latitude,
      "longitude": biz.longitude
    } : undefined,
    ...(avgRating > 0 ? {
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": avgRating.toFixed(1),
        "reviewCount": reviews.length
      }
    } : {})
  })} />

  <Header activePage="Listings" />

  <section class={`page-hero ${isElevated && bannerUrl ? 'hero-elevated' : ''}`} style={isElevated && bannerUrl ? `background-image: url(${bannerUrl})` : ''}>
    {isElevated && bannerUrl && <div class="hero-overlay"></div>}
    <div class="container hero-content">
      <a href="/listings/" class="back-link">&larr; All Listings</a>
      <div class="biz-header">
        {isElevated && logoUrl && (
          <img src={logoUrl} alt={`${biz.title} logo`} class="biz-logo" width="80" height="80" />
        )}
        <div>
          <h1>{biz.title}</h1>
          <div class="biz-badges">
            {isElevated && <span class="badge badge-elevated">★ Premium Listing</span>}
            {biz.featured && !isElevated && <span class="badge badge-featured">Featured</span>}
            {isVerified && <span class="badge badge-verified">&#10003; Verified</span>}
            {biz.tags?.includes('locally-owned') && <span class="badge badge-local">Locally Owned</span>}
            {avgRating > 0 && (
              <span class="badge badge-rating">
                {'★'.repeat(Math.round(avgRating))}{'☆'.repeat(5 - Math.round(avgRating))}
                <span class="rating-count">({reviews.length})</span>
              </span>
            )}
          </div>
        </div>
      </div>
      <div class="biz-quick-info">
        {biz.categories?.[0] && (
          <a href={`/categories/${biz.categories[0].toLowerCase().replace(/[&\s]+/g, '-').replace(/--+/g, '-')}/`} class="quick-tag">
            {biz.categories[0]}
          </a>
        )}
        {biz.location?.[0] && (
          <a href={`/locations/${biz.location[0].toLowerCase().replace(/\s+/g, '-')}/`} class="quick-tag">
            📍 {biz.location[0]}
          </a>
        )}
      </div>
      {isElevated && (cta1 || cta2) && (
        <div class="hero-ctas">
          {cta1 && <a href={cta1.url} target="_blank" rel="noopener noreferrer" class="btn btn-cta-primary">{cta1.label}</a>}
          {cta2 && <a href={cta2.url} target="_blank" rel="noopener noreferrer" class="btn btn-cta-secondary">{cta2.label}</a>}
        </div>
      )}
    </div>
  </section>

  {/* Non-featured: photo grid (build-time + client-side refresh) */}
  <section class="biz-gallery-section" id="photo-gallery" data-slug={biz.slug} data-title={biz.title} style={!isFeatured && photos.length > 0 ? '' : (!isFeatured ? 'display:none' : 'display:none')}>
    <div class="container">
      <h3 class="gallery-heading">Photos</h3>
      <div class="biz-photo-grid" id="photo-gallery-inner">
        {photos.map((photo: any) => (
          <img src={photo.url} alt={photo.alt_text || biz.title} loading="lazy" class="biz-photo-grid-img" data-lightbox />
        ))}
      </div>
    </div>
  </section>

  <section class="biz-content">
    <div class="container">
      <div class="biz-layout">
        <div class="biz-main">

          {/* ── FEATURED: Tabbed Mini-Website ── */}
          {isFeatured ? (
            <div class="mini-website">
              <div class="tab-bar" id="tab-bar">
                <button class="tab-btn active" data-tab="about">About</button>
                {hasServices && <button class="tab-btn" data-tab="services">Services</button>}
                {hasGallery && <button class="tab-btn" data-tab="gallery">Gallery</button>}
                {hasDeal && <button class="tab-btn" data-tab="deals">Deals</button>}
                <button class="tab-btn" data-tab="reviews">Reviews{reviews.length > 0 ? ` (${reviews.length})` : ''}</button>
              </div>

              {/* About Tab */}
              <div class="tab-panel active" id="tab-about">
                <div class="biz-description">
                  {biz.content && <p>{biz.content}</p>}
                  {!biz.content && <p class="text-gray">No description available yet.</p>}
                </div>
              </div>

              {/* Services Tab */}
              {hasServices && (
                <div class="tab-panel" id="tab-services">
                  <ul class="services-list">
                    {services.map((s: string) => (
                      <li>{s}</li>
                    ))}
                  </ul>
                </div>
              )}

              {/* Gallery Tab */}
              {hasGallery && (
                <div class="tab-panel" id="tab-gallery">
                  {isElevated && photos.length > 1 ? (
                    <div class="photo-carousel" id="photo-carousel">
                      <div class="carousel-track" id="carousel-track">
                        {photos.map((photo: any) => (
                          <img src={photo.url} alt={photo.alt_text || biz.title} loading="lazy" data-lightbox />
                        ))}
                      </div>
                      <button class="carousel-btn carousel-prev" id="carousel-prev" aria-label="Previous photo">&#8249;</button>
                      <button class="carousel-btn carousel-next" id="carousel-next" aria-label="Next photo">&#8250;</button>
                      <div class="carousel-dots" id="carousel-dots">
                        {photos.map((_: any, i: number) => (
                          <button class={`carousel-dot ${i === 0 ? 'active' : ''}`} data-idx={i} aria-label={`Photo ${i + 1}`}></button>
                        ))}
                      </div>
                    </div>
                  ) : (
                    <div class="tab-gallery-grid" id="featured-photo-grid">
                      {photos.map((photo: any) => (
                        <img src={photo.url} alt={photo.alt_text || biz.title} loading="lazy" class="tab-gallery-img" data-lightbox />
                      ))}
                    </div>
                  )}
                  {videoEmbedUrl && (
                    <div class="video-embed">
                      <iframe src={videoEmbedUrl} title={`${biz.title} video`} frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                    </div>
                  )}
                </div>
              )}

              {/* Deals Tab */}
              {hasDeal && (
                <div class="tab-panel" id="tab-deals">
                  {isElevated ? (
                    <div class="deal-box-elevated">
                      <h3>🎟️ {biz.deal_title}</h3>
                      {biz.deal_description && <p>{biz.deal_description}</p>}
                      {biz.deal_expiry && (
                        <div class="deal-countdown" id="deal-countdown" data-expiry={biz.deal_expiry}></div>
                      )}
                      {biz.deal_expiry && <span class="deal-expiry">Expires: {biz.deal_expiry}</span>}
                    </div>
                  ) : (
                    <div class="deal-box">
                      <h3>{biz.deal_title}</h3>
                      {biz.deal_description && <p>{biz.deal_description}</p>}
                      {biz.deal_expiry && <span class="deal-expiry">Expires: {biz.deal_expiry}</span>}
                    </div>
                  )}
                </div>
              )}

              {/* Reviews Tab */}
              <div class="tab-panel" id="tab-reviews">
                {reviews.length > 0 ? (
                  <div class="reviews-list">
                    {reviews.map((r: any) => (
                      <div class="review-card">
                        <div class="review-header">
                          <span class="review-stars">{'★'.repeat(r.rating)}{'☆'.repeat(5 - r.rating)}</span>
                          <span class="review-author">{r.reviewer_name}</span>
                          <span class="review-date">{new Date(r.created_at).toLocaleDateString()}</span>
                        </div>
                        {r.review_text && <p class="review-text">{r.review_text}</p>}
                      </div>
                    ))}
                  </div>
                ) : (
                  <p class="no-reviews">No reviews yet. Be the first!</p>
                )}
                <div class="review-form-section">
                  <h4>Leave a Review</h4>
                  <form id="review-form" class="review-form">
                    <input type="hidden" id="review-slug" value={biz.slug} />
                    <div class="form-row">
                      <div>
                        <label for="reviewer-name">Your Name *</label>
                        <input type="text" id="reviewer-name" required />
                      </div>
                      <div>
                        <label for="review-rating">Rating *</label>
                        <select id="review-rating" required>
                          <option value="">Select...</option>
                          <option value="5">★★★★★ (5)</option>
                          <option value="4">★★★★☆ (4)</option>
                          <option value="3">★★★☆☆ (3)</option>
                          <option value="2">★★☆☆☆ (2)</option>
                          <option value="1">★☆☆☆☆ (1)</option>
                        </select>
                      </div>
                    </div>
                    <div>
                      <label for="review-text">Your Review</label>
                      <textarea id="review-text" rows="3" placeholder="Share your experience..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-teal" id="review-submit">Submit Review</button>
                    <p class="review-note">Reviews are moderated and will appear after approval.</p>
                    <div id="review-message" class="review-message"></div>
                  </form>
                </div>
              </div>
            </div>
          ) : (
            /* ── NON-FEATURED: Simple layout ── */
            <>
              {biz.content && (
                <div class="biz-description">
                  <h2>About</h2>
                  <p>{biz.content}</p>
                </div>
              )}

              {biz.deal_title && (
                <div class="deal-section">
                  <div class="deal-header">
                    <span class="deal-icon">🎟️</span>
                    <h2>Current Deal</h2>
                  </div>
                  <div class="deal-box">
                    <h3>{biz.deal_title}</h3>
                    {biz.deal_description && <p>{biz.deal_description}</p>}
                    {biz.deal_expiry && <span class="deal-expiry">Expires: {biz.deal_expiry}</span>}
                  </div>
                </div>
              )}
            </>
          )}

          {related.length > 0 && !isElevated && (
            <div class="related-section">
              <h2>Related Businesses</h2>
              <div class="related-grid">
                {related.map((r: any) => (
                  <a href={`/listing/${r.slug}/`} class="related-card">
                    <h4>{r.title}</h4>
                    <div class="related-meta">
                      {r.categories?.[0] && <span>{r.categories[0]}</span>}
                      {r.location?.[0] && <span>📍 {r.location[0]}</span>}
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>

        <aside class="biz-sidebar">
          <div class="sidebar-card">
            <h3>Contact & Location</h3>
            {biz.address && (
              <div class="sidebar-item">
                <span class="sidebar-icon">📍</span>
                <div><strong>Address</strong><p>{biz.address}</p></div>
              </div>
            )}
            {biz.phone && (
              <div class="sidebar-item">
                <span class="sidebar-icon">📞</span>
                <div><strong>Phone</strong><p><a href={`tel:${biz.phone.replace(/[^\d+]/g, '')}`}>{biz.phone}</a></p></div>
              </div>
            )}
            {biz.email && (
              <div class="sidebar-item">
                <span class="sidebar-icon">✉️</span>
                <div><strong>Email</strong><p><a href={`mailto:${biz.email}`}>{biz.email}</a></p></div>
              </div>
            )}
            {biz.website && (
              <div class="sidebar-item">
                <span class="sidebar-icon">🌐</span>
                <div><strong>Website</strong><p><a href={biz.website} target="_blank" rel="noopener noreferrer">{biz.website.replace(/^https?:\/\/(www\.)?/, '').replace(/\/$/, '')}</a></p></div>
              </div>
            )}
            {biz.address && (
              <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(biz.address)}`} target="_blank" rel="noopener noreferrer" class="btn btn-teal">Get Directions &rarr;</a>
            )}

            {/* Social Media Links — Elevated only */}
            {isElevated && socialLinks.length > 0 && (
              <div class="social-links">
                {socialLinks.map(s => (
                  <a href={s.url} target="_blank" rel="noopener noreferrer" class={`social-icon social-${s.icon}`} aria-label={s.name} title={s.name}>
                    {s.icon === 'fb' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>}
                    {s.icon === 'ig' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>}
                    {s.icon === 'tw' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>}
                    {s.icon === 'li' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>}
                    {s.icon === 'tt' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>}
                    {s.icon === 'yt' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>}
                  </a>
