  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Tab switching
    const tabBar = document.getElementById('tab-bar');
    if (tabBar) {
      const buttons = tabBar.querySelectorAll('.tab-btn');
      const panels = document.querySelectorAll('.tab-panel');
      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const tabId = btn.getAttribute('data-tab');
          buttons.forEach(b => b.classList.remove('active'));
          panels.forEach(p => p.classList.remove('active'));
          btn.classList.add('active');
          const target = document.getElementById(`tab-${tabId}`);
          if (target) target.classList.add('active');
        });
      });
    }

    // Lightbox
    const images = document.querySelectorAll('[data-lightbox]');
    if (images.length) {
      const srcs = Array.from(images).map(img => (img as HTMLImageElement).src);
      let currentIdx = 0;
      function openLightbox(idx: number) {
        currentIdx = idx;
        const overlay = document.createElement('div');
        overlay.className = 'lightbox-overlay';
        overlay.innerHTML = `
          <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
          ${srcs.length > 1 ? '<button class="lightbox-nav lightbox-prev" aria-label="Previous photo">&lsaquo;</button>' : ''}
          <img src="${srcs[idx]}" alt="Photo" />
          ${srcs.length > 1 ? '<button class="lightbox-nav lightbox-next" aria-label="Next photo">&rsaquo;</button>' : ''}
        `;
        overlay.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (target.classList.contains('lightbox-overlay') || target.classList.contains('lightbox-close')) { overlay.remove(); }
          else if (target.classList.contains('lightbox-prev')) { currentIdx = (currentIdx - 1 + srcs.length) % srcs.length; (overlay.querySelector('img') as HTMLImageElement).src = srcs[currentIdx]; }
          else if (target.classList.contains('lightbox-next')) { currentIdx = (currentIdx + 1) % srcs.length; (overlay.querySelector('img') as HTMLImageElement).src = srcs[currentIdx]; }
        });
        document.addEventListener('keydown', function handler(e) {
          if (e.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', handler); }
          if (e.key === 'ArrowLeft') { currentIdx = (currentIdx - 1 + srcs.length) % srcs.length; (overlay.querySelector('img') as HTMLImageElement).src = srcs[currentIdx]; }
          if (e.key === 'ArrowRight') { currentIdx = (currentIdx + 1) % srcs.length; (overlay.querySelector('img') as HTMLImageElement).src = srcs[currentIdx]; }
        });
        document.body.appendChild(overlay);
      }
      images.forEach((img, idx) => { img.addEventListener('click', () => openLightbox(idx)); });
    }

    // Client-side photo refresh — fetches latest photos from Supabase
    const gallerySection = document.getElementById('photo-gallery');
    const slug = gallerySection?.dataset.slug;
    const bizTitle = gallerySection?.dataset.title || '';
    if (slug) {
      fetch(`/api/photos?slug=${encodeURIComponent(slug)}`)
        .then(r => r.json())
        .then(({ photos: freshPhotos }) => {
          if (!freshPhotos || freshPhotos.length === 0) return;

          // Non-featured gallery
          const galleryInner = document.getElementById('photo-gallery-inner');
          if (galleryInner && gallerySection) {
            gallerySection.style.display = '';
            galleryInner.innerHTML = freshPhotos.map((p: any) =>
              `<img src="${p.url}" alt="${p.alt_text || bizTitle}" loading="lazy" class="biz-photo-grid-img" data-lightbox />`
            ).join('');
          }

          // Featured gallery tab
          const featuredGrid = document.getElementById('featured-photo-grid');
          if (featuredGrid) {
            featuredGrid.innerHTML = freshPhotos.map((p: any) =>
              `<img src="${p.url}" alt="${p.alt_text || bizTitle}" loading="lazy" class="tab-gallery-img" data-lightbox />`
            ).join('');
            // Show gallery tab button if it was hidden
            const galleryTabBtn = document.querySelector('[data-tab="gallery"]') as HTMLElement;
            if (galleryTabBtn) galleryTabBtn.style.display = '';
          }

          // Re-bind lightbox for new images
          const newImages = document.querySelectorAll('[data-lightbox]');
          if (newImages.length) {
            const srcs = Array.from(newImages).map(img => (img as HTMLImageElement).src);
            let currentIdx = 0;
            function openLB(idx: number) {
              currentIdx = idx;
              const overlay = document.createElement('div');
              overlay.className = 'lightbox-overlay';
              overlay.innerHTML = `
                <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
                ${srcs.length > 1 ? '<button class="lightbox-nav lightbox-prev" aria-label="Previous photo">&lsaquo;</button>' : ''}
                <img src="${srcs[idx]}" alt="Photo" />
                ${srcs.length > 1 ? '<button class="lightbox-nav lightbox-next" aria-label="Next photo">&rsaquo;</button>' : ''}
              `;
              overlay.addEventListener('click', (e) => {
                const target = e.target as HTMLElement;
                if (target.classList.contains('lightbox-overlay') || target.classList.contains('lightbox-close')) { overlay.remove(); }
                else if (target.classList.contains('lightbox-prev')) { currentIdx = (currentIdx - 1 + srcs.length) % srcs.length; (overlay.querySelector('img') as HTMLImageElement).src = srcs[currentIdx]; }
                else if (target.classList.contains('lightbox-next')) { currentIdx = (currentIdx + 1) % srcs.length; (overlay.querySelector('img') as HTMLImageElement).src = srcs[currentIdx]; }
              });
              document.addEventListener('keydown', function handler(e) {
                if (e.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', handler); }
                if (e.key === 'ArrowLeft') { currentIdx = (currentIdx - 1 + srcs.length) % srcs.length; (overlay.querySelector('img') as HTMLImageElement).src = srcs[currentIdx]; }
                if (e.key === 'ArrowRight') { currentIdx = (currentIdx + 1) % srcs.length; (overlay.querySelector('img') as HTMLImageElement).src = srcs[currentIdx]; }
              });
              document.body.appendChild(overlay);
            }
            newImages.forEach((img, idx) => { img.addEventListener('click', () => openLB(idx)); });
          }
        })
        .catch(() => { /* silently fail — build-time photos still work */ });
    }

    // Photo Carousel (Elevated)
    const carousel = document.getElementById('photo-carousel');
    if (carousel) {
      const track = document.getElementById('carousel-track') as HTMLElement;
      const slides = track.querySelectorAll('img');
      const dots = document.querySelectorAll('.carousel-dot');
      const prevBtn = document.getElementById('carousel-prev');
      const nextBtn = document.getElementById('carousel-next');
      let current = 0;
      const total = slides.length;
      function goTo(idx: number) {
        current = ((idx % total) + total) % total;
        track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
      }
      prevBtn?.addEventListener('click', () => goTo(current - 1));
      nextBtn?.addEventListener('click', () => goTo(current + 1));
      dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
      // Auto-advance every 5 seconds
      let autoPlay = setInterval(() => goTo(current + 1), 5000);
      carousel.addEventListener('mouseenter', () => clearInterval(autoPlay));
      carousel.addEventListener('mouseleave', () => { autoPlay = setInterval(() => goTo(current + 1), 5000); });
    }

    // Business Hours — highlight today + open/closed indicator
    const hoursTable = document.getElementById('hours-table');
    const openStatus = document.getElementById('open-status');
    if (hoursTable && openStatus) {
      const days = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'];
      const now = new Date();
      const todayKey = days[now.getDay()];
      const rows = hoursTable.querySelectorAll('.hours-row');
      rows.forEach(row => {
        if ((row as HTMLElement).dataset.day === todayKey) {
          row.classList.add('today');
        }
      });
      // Simple open/closed check
      const todayRow = hoursTable.querySelector(`[data-day="${todayKey}"]`);
      const timeText = todayRow?.querySelector('.hours-time')?.textContent?.trim() || '';
      if (timeText === 'Closed' || timeText === '—') {
        openStatus.textContent = '🔴 Closed Today';
        openStatus.classList.add('is-closed');
      } else if (timeText.includes('–')) {
        // Parse times (basic)
        const parts = timeText.split('–').map(t => t.trim());
        const parseTime = (s: string) => {
          const m = s.match(/(\d+):(\d+)\s*(AM|PM)/i);
          if (!m) return -1;
          let h = parseInt(m[1]);
          const min = parseInt(m[2]);
          if (m[3].toUpperCase() === 'PM' && h !== 12) h += 12;
          if (m[3].toUpperCase() === 'AM' && h === 12) h = 0;
          return h * 60 + min;
        };
        const openMin = parseTime(parts[0]);
        const closeMin = parseTime(parts[1]);
        const nowMin = now.getHours() * 60 + now.getMinutes();
        if (openMin >= 0 && closeMin >= 0 && nowMin >= openMin && nowMin <= closeMin) {
          openStatus.textContent = '🟢 Open Now';
          openStatus.classList.add('is-open');
        } else {
          openStatus.textContent = '🔴 Closed Now';
          openStatus.classList.add('is-closed');
        }
      }
    }

    // Deal Countdown (Elevated)
    const countdownEl = document.getElementById('deal-countdown');
    if (countdownEl) {
      const expiry = countdownEl.dataset.expiry;
      if (expiry) {
        const expiryDate = new Date(expiry + 'T23:59:59');
        function updateCountdown() {
          const now = new Date();
          const diff = expiryDate.getTime() - now.getTime();
          if (diff <= 0) { countdownEl!.innerHTML = '<span style="color: #dc2626; font-weight: 600;">Deal Expired</span>'; return; }
          const d = Math.floor(diff / (1000 * 60 * 60 * 24));
          const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
          countdownEl!.innerHTML = `
            <div class="countdown-unit"><span class="countdown-num">${d}</span><span class="countdown-label">Days</span></div>
            <div class="countdown-unit"><span class="countdown-num">${h}</span><span class="countdown-label">Hours</span></div>
            <div class="countdown-unit"><span class="countdown-num">${m}</span><span class="countdown-label">Min</span></div>
          `;
        }
        updateCountdown();
        setInterval(updateCountdown, 60000);
      }
    }

    // Review form submission
    const reviewForm = document.getElementById('review-form') as HTMLFormElement;
    if (reviewForm) {
      reviewForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = document.getElementById('review-submit') as HTMLButtonElement;
        const msgDiv = document.getElementById('review-message') as HTMLElement;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Submitting...';
        msgDiv.textContent = '';
        msgDiv.className = 'review-message';
        try {
          const data = {
            slug: (document.getElementById('review-slug') as HTMLInputElement).value,
            name: (document.getElementById('reviewer-name') as HTMLInputElement).value,
            rating: parseInt((document.getElementById('review-rating') as HTMLSelectElement).value),
            text: (document.getElementById('review-text') as HTMLTextAreaElement).value,
          };
          const res = await fetch('/api/review', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
          const result = await res.json();
          if (res.ok) {
            msgDiv.textContent = 'Thank you! Your review has been submitted for approval.';
            msgDiv.className = 'review-message success';
            reviewForm.reset();
          } else {
            msgDiv.textContent = result.error || 'Something went wrong. Please try again.';
            msgDiv.className = 'review-message error';
          }
        } catch {
          msgDiv.textContent = 'Network error. Please try again.';
          msgDiv.className = 'review-message error';
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit Review';
        }
      });
    }
  });
</script>
